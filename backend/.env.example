PORT=5000
NODE_ENV=development

# MongoDB Connection
MONGODB_URI=mongodb://localhost:27017/clovas-shopping

# Firebase Config (for Admin SDK token validation)
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY\n-----END PRIVATE KEY-----"

# Alternatively, paste full Firebase service account JSON string as a single line
FIREBASE_SERVICE_ACCOUNT_JSON=

# Cloudinary Credentials (for product image uploads)
CLOUDINARY_CLOUD_NAME=your-cloudinary-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# SSLCommerz Configuration (set Store ID and Passwd to 'testbox' to auto-mock sandbox redirects)
SSLCOMMERZ_STORE_ID=testbox
SSLCOMMERZ_STORE_PASSWORD=testbox
SSLCOMMERZ_SANDBOX=true

# Application URLs
BACKEND_URL=http://localhost:5000
FRONTEND_URL=http://127.0.0.1:5500/frontend

# Mock configuration for easy manual verification without setting up external accounts
MOCK_PAYMENT=true
