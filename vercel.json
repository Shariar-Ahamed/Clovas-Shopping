{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/fHome", "destination": "/frontend/index.html" },
    { "source": "/fShop", "destination": "/frontend/shop.html" },
    { "source": "/css/:path*", "destination": "/frontend/css/:path*" },
    { "source": "/js/:path*", "destination": "/frontend/js/:path*" },
    { "source": "/assets/:path*", "destination": "/frontend/assets/:path*" },
    { "source": "/admin/:path*", "destination": "/frontend/admin/:path*" },
    { "source": "/:page.html", "destination": "/frontend/:page.html" }
  ]
}
