{
  "version": 2,
  "cleanUrls": true,
  "builds": [
    { "src": "backend/server.js", "use": "@vercel/node" },
    { "src": "frontend/**", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/server.js" },
    { "src": "/__/auth/(.*)", "dest": "https://clovas-shop.firebaseapp.com/__/auth/$1" },
    { "src": "^/css/(.*)", "dest": "frontend/css/$1" },
    { "src": "^/js/(.*)", "dest": "frontend/js/$1" },
    { "src": "^/assets/(.*)", "dest": "frontend/assets/$1" },
    { "src": "^/admin/?$", "dest": "frontend/admin/index.html" },
    { "src": "^/admin/index$", "dest": "frontend/admin/index.html" },
    { "src": "^/admin/(.*\\.[a-zA-Z0-9]+)$", "dest": "frontend/admin/$1" },
    { "src": "^/admin/(.*)$", "dest": "frontend/admin/$1.html" },
    { "src": "^/$", "dest": "frontend/index.html" },
    { "src": "^/index$", "dest": "frontend/index.html" },
    { "src": "^/(.*\\.[a-zA-Z0-9]+)$", "dest": "frontend/$1" },
    { "src": "^/(.*)$", "dest": "frontend/$1.html" }
  ]
}
